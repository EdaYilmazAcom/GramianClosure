Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Relative", " ", "Error", " ", "of", " ", "the", " ", "Gramian", " ", 
    RowBox[{"Closure", ":", 
     RowBox[{"The", " ", "Even", " ", "case"}]}]}], "*)"}], " ", 
  "\[IndentingNewLine]", 
  RowBox[{
