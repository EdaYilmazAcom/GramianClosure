Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Grad", " ", "distribution", " ", 
     RowBox[{"f", "^", 
      RowBox[{"(", "Grad", ")"}]}], 
     RowBox[{"(", "c", ")"}]}], ":=", 
    RowBox[{
     RowBox[{"fG", "[", "\[Xi]", "]"}], " ", "and", " ", "coefficient", " ", 
     "matrix", " ", "are", " ", "defined"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Clear", "[", "NextGrad", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coefs", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"\[Alpha]", "[", "k", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", 
         RowBox[{"Mmax", "+", "1"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fG", "[", "\[Xi]_", "]"}], "=", 
     RowBox[{
      FractionBox["1", 
       SqrtBox[
        RowBox[{"2", "\[Pi]"}]]], 
      RowBox[{"Exp", "[", 
       RowBox[{"-", 
        FractionBox[
         SuperscriptBox["\[Xi]", "2"], "2"]}], "]"}], 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Alpha]", "[", "k", "]"}], 
         SuperscriptBox["\[Xi]", "k"]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", 
          RowBox[{"Mmax", "+", "1"}]}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Atmp", "=", 
     RowBox[{"Normal", "[", 
      RowBox[{
       RowBox[{"CoefficientArrays", "[", 
        RowBox[{
         RowBox[{"Integrate", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              SuperscriptBox["\[Xi]", "k"], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "0", ",", 
                RowBox[{"Mmax", "+", "1"}]}], "}"}]}], "]"}], " ", 
            RowBox[{"fG", "[", "\[Xi]", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Xi]", ",", 
             RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], 
          "]"}], ",", "coefs"}], "]"}], "[", 
       RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"NextGrad", "[", "M", "]"}], "=", 
      RowBox[{
       RowBox[{"Atmp", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"M", "+", "2"}], ",", 
          RowBox[{"1", ";;", 
           RowBox[{"M", "+", "1"}]}]}], "]"}], "]"}], ".", 
       RowBox[{"Inverse", "[", 
        RowBox[{"Atmp", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"1", ";;", 
