a2a587763157"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Convective", " ", "&"}], " ", "Central", " ", "Moments"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"equations", "[", "len_", "]"}], ":=", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Binomial", "[", 
           RowBox[{"k", ",", "j"}], "]"}], 
          SuperscriptBox["v", "j"], 
          RowBox[{"\[Rho]", "[", 
           RowBox[{"k", "-", "j"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", "k"}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "0", ",", 
         RowBox[{"len", "-", "1"}]}], "}"}]}], "]"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Rho]", "[", "1", "]"}], "->", "0"}], "}"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Rho]2m", "[", "\[Rho]List_", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"len", "=", 
         RowBox[{"Length", "[", "\[Rho]List", "]"}]}], ",", "\[Rho]Var"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Rho]Var", "=", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"\[Rho]", "[", "i", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "0", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}]}], "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Rho]", "[", "1", "]"}], "->", "v"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"equations", "[", "len", "]"}], "/.", 
        RowBox[{"Thread", "[", 
         RowBox[{"\[Rho]Var", "->", "\[Rho]List"}], "]"}]}]}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m2\[Rho]", "[", "mList_", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"len", "=", 
         RowBox[{"Length", "[", "mList", "]"}]}], ",", "\[Rho]Var"}], "}"}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Rho]Var", "=", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"\[Rho]", "[", "i", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "0", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}]}], "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Rho]", "[", "1", "]"}], "->", "v"}], "}"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[Rho]Var", "/.", 
        RowBox[{
         RowBox[{"NSolve", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"equations", "[", "len", "]"}], "==", "mList"}], ",", 
           "\[Rho]Var"}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}],
    "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Grad", " ", "closure"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Gradd", "[", "conlist_", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"len", "=", 
         RowBox[{"Length", "[", "conlist", "]"}]}], ",", "soln", ",", "moms", 
        ",", "eqns", ",", "a", ",", "\[Rho]", ",", "\[Theta]", ",", "scale", 
        ",", "dimless"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"convective", " ", "to", " ", "central"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"CentmomList", "=", 
        RowBox[{"m2\[Rho]", "[", "conlist", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", "Dimensionalization", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"\[Rho]", "=", 
        RowBox[{"CentmomList", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"a", "=", 
        RowBox[{"CentmomList", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Theta]", "=", 
        RowBox[{
         RowBox[{"CentmomList", "[", 
          RowBox[{"[", "3", "]"}], "]"}], "/", "\[Rho]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"CentmomList", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "=", "0"}], ";", 
       "                                     ", "\[IndentingNewLine]", 
       RowBox[{"scale", "=", 
        RowBox[{"\[Rho]", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           SuperscriptBox["\[Theta]", 
            RowBox[{"k", "/", "2"}]], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "0", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dimless", "=", 
        RowBox[{
         SuperscriptBox["scale", 
          RowBox[{"-", "1"}]], "CentmomList"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"NextmomentCentr", "=", 
        RowBox[{
         RowBox[{"NextGrad", "[", 
          RowBox[{"len", "-", "1"}], "]"}], ".", "dimless"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"CentmomList", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "=", "a"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"momList2", "=", 
        RowBox[{"\[Rho]2m", "[", 
         RowBox[{"Join", "[", 
          RowBox[{"CentmomList", ",", 
           RowBox[{"{", 
            RowBox[{"\[Rho]", " ", 
             SuperscriptBox["\[Theta]", 
              RowBox[{
               RowBox[{"(", "len", ")"}], "/", "2"}]], "NextmomentCentr"}], 
            "}"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"NextMomentConvariant", "=", 
        RowBox[{"momList2", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "NextMomentConvariant"}]}], "\[IndentingNewLine]", 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.933146054084852*^9, 3.9331460763735237`*^9}, {
   3.933146186544781*^9, 3.933146221570187*^9}, {3.9331463112404156`*^9, 
   3.9331463352250013`*^9}, {3.93314638663419*^9, 3.933146389597911*^9}, {
   3.9331464239575963`*^9, 3.9331464357923574`*^9}, 3.9331481142906203`*^9, 
   3.9331481655017853`*^9},
 CellLabel->"In[30]:=",ExpressionUUID->"13a0ec55-170d-4c45-97bf-2793fa4ae4be"]
}, Closed]],

