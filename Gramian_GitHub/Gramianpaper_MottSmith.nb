Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"computation", " ", "of", " ", "first", " ", "M"}], "+", 
    RowBox[{
    "1", " ", "moments", " ", "using", " ", "underlying", " ", "distribution",
      " ", "function", " ", "fhid"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"uhid", ",", "uhidnextmoment", ",", "momList"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"uhid", "=", 
     RowBox[{"Association", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", "->", 
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{"ExpandAll", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", "c", ")"}], "k"], ",", 
                RowBox[{"{", 
                 RowBox[{"k", ",", "0", ",", 
                  RowBox[{"Mmax", "+", "1"}]}], "}"}]}], "]"}], 
              RowBox[{"fhid", "[", 
               RowBox[{"c", ",", "x"}], "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"c", ",", 
              RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], 
           "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "xvalues"}], "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"momList", "[", 
      RowBox[{"M_", ",", "x_"}], "]"}], ":=", 
     RowBox[{"Chop", "[", 
      RowBox[{
       RowBox[{"uhid", "[", "x", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ";;", 
         RowBox[{"M", "+", "1"}]}], "]"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"uhidnextmoment", "[", 
      RowBox[{"M_", ",", "x_"}], "]"}], ":=", 
     RowBox[{"Chop", "[", 
      RowBox[{
       RowBox[{"uhid", "[", "x", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"M", "+", "2"}], "]"}], "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9331470500273895`*^9, 3.933147183090827*^9}, {
