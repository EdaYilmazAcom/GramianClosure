         RowBox[{
          RowBox[{"2", "n"}], "-", "3"}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"a4", "=", 
        RowBox[{"momList", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"n", "+", "s1"}], ";;", 
           RowBox[{
            RowBox[{"2", "n"}], "-", "2", "+", "s1"}]}], "]"}], "]"}]}], ";", 
       "                                      ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"a4", " ", "=", " ", "u_n"}], ",", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "2"}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"c", "=", 
        RowBox[{
         RowBox[{"Inverse", "[", "G2", "]"}], ".", 
         RowBox[{"Transpose", "[", "a3", "]"}]}]}], ";", 
       "                                            ", 
       RowBox[{"(*", 
        RowBox[{"c", " ", "=", " ", 
         RowBox[{
          SuperscriptBox["Gn2", 
           RowBox[{"-", "1"}]], ".", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"u_n", "-", "1"}], ",", 
             RowBox[{
              RowBox[{"2", "n"}], "-", "3"}]}], ")"}], "^", "T"}]}]}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"u_closure", " ", ":=", " ", 
           RowBox[{
            RowBox[{"u_", "2", "n"}], " ", "=", " ", 
            RowBox[{"u_n", "+", "1"}]}]}], ",", 
          RowBox[{
           RowBox[{"2", "n"}], "-", 
           RowBox[{"1.", 
            RowBox[{
             SuperscriptBox["Gn2", 
              RowBox[{"-", "1"}]], ".", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"u_n", "-", "1"}], ",", 
                RowBox[{
                 RowBox[{"2", "n"}], "-", "3"}]}], ")"}], "^", "T"}]}]}], " ",
            "+", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", "+", "1"}], ")"}], "/", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", "n"}], ")"}], ".", 
              RowBox[{"(", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"u_", "2", "n"}], "-", "1", " ", "-", " ", "u_n"}],
                   ",", 
                  RowBox[{
                   RowBox[{"2", "n"}], "-", 
                   RowBox[{"2.", 
                    RowBox[{
                    SuperscriptBox["Gn2", 
                    RowBox[{"-", "1"}]], ".", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"u_n", "-", "1"}], ",", 
                    RowBox[{
                    RowBox[{"2", "n"}], "-", "3"}]}], ")"}], "^", 
                    "T"}]}]}]}]}], ")"}], "^", "2"}], ")"}]}]}], " ", "/", 
            " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"u_", "2", "n"}], "-", "2", " ", "-", " ", "u_n", "-", 
               "1"}], ",", 
              RowBox[{
               RowBox[{"2", "n"}], "-", 
               RowBox[{"3.", 
                RowBox[{
                 SuperscriptBox["Gn2", 
                  RowBox[{"-", "1"}]], ".", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"u_n", "-", "1"}], ",", 
                    RowBox[{
                    RowBox[{"2", "n"}], "-", "3"}]}], ")"}], "^", 
                  "T"}]}]}]}]}], ")"}]}]}]}], ")"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"NextmomentO", "=", 
        RowBox[{
         RowBox[{"a5", " ", ".", "c"}], "+", 
         RowBox[{"chi", 
          RowBox[{"(", 
           RowBox[{
