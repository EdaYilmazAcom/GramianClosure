       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"a5", " ", "=", " ", 
          RowBox[{"u_n", "+", "1"}]}], ",", 
         RowBox[{
          RowBox[{"2", "n"}], "-", "1"}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"a3", "=", 
        RowBox[{"momList", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"n", "-", "1", "+", "s1"}], ";;", 
           RowBox[{
            RowBox[{"2", "n"}], "-", "3", "+", "s1"}]}], "]"}], "]"}]}], ";", 
