Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"FIX", " ", "Parameters"}], "*)"}], " ", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Gamma]", "=", 
     RowBox[{"5", "/", "3"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"fMottSmith", ":=", " ", 
     RowBox[{"f_MS", 
      RowBox[{"(", 
       RowBox[{"Ma", ",", "x", ",", "c", ",", "\[Gamma]"}], ")"}]}]}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fMottSmith", "[", 
     RowBox[{"M0_", ",", "x_", ",", "c_"}], "]"}], ":=", 
    RowBox[{"fbimodal", "[", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"Exp", "[", "x", "]"}]}], ")"}]}], ",", 
