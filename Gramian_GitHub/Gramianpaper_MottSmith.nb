Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"fbimodal", ":=", " ", 
    RowBox[{"f_BM", 
     RowBox[{"(", 
      RowBox[{
      "\[Rho]1", ",", "v1", ",", "\[Theta]1", ",", "\[Rho]2", ",", "v2", ",", 
       "\[Theta]2", ",", "c"}], ")"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"fbimodal", "[", 
      RowBox[{
      "\[Rho]1_", ",", "v1_", ",", "\[Theta]1_", ",", "\[Rho]2_", ",", "v2_", 
       ",", "\[Theta]2_", ",", "Cc_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Rho]1", "/", 
         RowBox[{"(", 
          RowBox[{"\[Sqrt]", 
           RowBox[{"(", 
            RowBox[{"2", "\[Pi]", " ", "\[Theta]1"}], ")"}]}], ")"}]}], ")"}], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"Cc", "-", "v1"}], ")"}], "2"]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", "\[Theta]1"}], ")"}]}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Rho]2", "/", 
         RowBox[{"(", 
          RowBox[{"\[Sqrt]", 
           RowBox[{"(", 
            RowBox[{"2", "\[Pi]", " ", "\[Theta]2"}], ")"}]}], ")"}]}], ")"}], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"Cc", "-", "v2"}], ")"}], "2"]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", "\[Theta]2"}], ")"}]}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "M0", "]"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Rankine", "-", 
     RowBox[{"Hugoniot", " ", "conditions"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"pRH", "[", "M0_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "\[Gamma]", "+", 
        RowBox[{"2", "\[Gamma]", " ", 
         SuperscriptBox["M0", "2"]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", "+", "\[Gamma]"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Rho]RH", "[", "M0_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["M0", "2"], 
        RowBox[{"(", 
         RowBox[{"\[Gamma]", "+", "1"}], ")"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "+", 
        RowBox[{
         SuperscriptBox["M0", "2"], 
         RowBox[{"(", 
          RowBox[{"\[Gamma]", "-", "1"}], ")"}]}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Theta]RH", "[", "M0_", "]"}], ":=", 
     RowBox[{
      RowBox[{"pRH", "[", "M0", "]"}], "/", 
      RowBox[{"\[Rho]RH", "[", "M0", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"vRH", "[", "M0_", "]"}], ":=", 
      RowBox[{
       RowBox[{"\[Sqrt]", "\[Gamma]"}], 
       RowBox[{"M0", "/", 
        RowBox[{"\[Rho]RH", "[", "M0", "]"}]}]}]}], ";"}], 
    RowBox[{"(*", " ", 
     RowBox[{"velocity", " ", "scaled", " ", "with", " ", 
      RowBox[{"\[Sqrt]", 
       SubscriptBox["\[Theta]", "0"]}]}], " ", "*)"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"vRH", "[", "M0_", "]"}], ":=", 
     RowBox[{"M0", "/", 
      RowBox[{"\[Rho]RH", "[", "M0", "]"}]}]}], ";"}], 
   RowBox[{"(*", " ", 
    RowBox[{
    "velocity", " ", "scaled", " ", "with", " ", "sound", " ", "speed", " ", 
     SubscriptBox["a", "0"]}], " ", "*)"}]}]}]], "Input",
 CellChangeTimes->{
