       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"Exp", "[", "x", "]"}]}], ")"}]}]}], ")"}], 
       RowBox[{"\[Rho]RH", "[", "M0", "]"}]}], ",", 
      RowBox[{
       RowBox[{"\[Sqrt]", "\[Gamma]"}], " ", 
       RowBox[{"vRH", "[", "M0", "]"}]}], ",", 
      RowBox[{"\[Theta]RH", "[", "M0", "]"}], ",", "c"}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"M0", "=", "4"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fhid", "[", 
      RowBox[{"c_", ",", "x_"}], "]"}], ":=", 
     RowBox[{"fMottSmith", "[", 
      RowBox[{"M0", ",", "x", ",", "c"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fMottSmith", "[", 
        RowBox[{"M0", ",", "x", ",", "c"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", 
         RowBox[{"-", "5"}], ",", "10"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}]}]}]], "Input",
