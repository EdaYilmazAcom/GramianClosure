      "\[IndentingNewLine]", 
      RowBox[{"var", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"f", "[", "i", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"Transpose", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"dc", " ", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"j", "\[Equal]", "0"}], ",", "1", ",", 
             SuperscriptBox[
              RowBox[{"c", "[", "i", "]"}], "j"]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "0", ",", "M"}], "}"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"fhidList", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"fhid", "[", 
          RowBox[{
           RowBox[{"c", "[", "i", "]"}], ",", "v2"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "n"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"moms$discrete", "=", 
       RowBox[{"A", ".", "fhidList"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"solE", "=", 
       RowBox[{"Thread", "[", 
        RowBox[{"var", "->", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"dc", ",", 
           RowBox[{"Length", "[", "var", "]"}]}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", "optimization", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"min$discrete", "=", 
       RowBox[{"FindMinimum", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"var", ".", 
            RowBox[{"Log", "[", 
             RowBox[{"var", "+", " ", "\[CurlyEpsilon]1"}], "]"}]}], ",", 
           RowBox[{"Thread", "[", 
            RowBox[{
             RowBox[{"A", ".", "var"}], "\[Equal]", "moms$discrete"}], "]"}], 
           ",", 
           RowBox[{"Thread", "[", 
            RowBox[{"var", "\[GreaterEqual]", "0"}], "]"}]}], "}"}], ",", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"var", ",", 
            RowBox[{"var", "/.", "solE"}]}], "}"}], "]"}], ",", 
         RowBox[{"MaxIterations", "\[Rule]", "200"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "using", " ", "optimize", " ", "distribution", " ", "calculation", 
         " ", "of", " ", "next", " ", "higher", " ", "moment"}], " ", ":=", 
        " ", "u_closure"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"nextmomentfromMEAlgomoms$disc", ":=", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"dc", " ", 
           SuperscriptBox[
            RowBox[{"c", "[", "i", "]"}], 
            RowBox[{"M", "+", "1"}]], 
           RowBox[{"f", "[", "i", "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], "/.", 
        RowBox[{"min$discrete", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "next", " ", "higher", " ", "moment", " ", "from", " ", "underlying", 
         " ", "discrete", " ", "distribution"}], " ", ":=", " ", 
        RowBox[{"u_M", "+", "1"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"uhidnextmomentdiscrete", "=", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{"dc", " ", 
          SuperscriptBox[
