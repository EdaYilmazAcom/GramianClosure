           RowBox[{"M", "+", "1"}]], 
          RowBox[{"fhid", "[", 
           RowBox[{
            RowBox[{"c", "[", "i", "]"}], ",", "v2"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "nextmomentfromMEAlgomoms$disc"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
