  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ErrorMEbimodal", "[", 
    RowBox[{"M_", ",", "v2_", ",", "cmin_", ",", "cmax_", ",", "n_"}], "]"}], 
   ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
