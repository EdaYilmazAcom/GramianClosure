    "To", " ", "use", " ", "same", " ", "notation", " ", "in", " ", "methods",
      " ", "with", " ", "other", " ", "distributions", " ", "functions", " ", 
     "I", " ", "have", " ", "changed", " ", "v", " ", "as", " ", "c"}], " ", 
