      "dc", ",", "c", ",", "pts", ",", "var", ",", "A", ",", "i", ",", "f", 
       ",", "fhidList", ",", "moms$discrete", ",", "solE"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", "discretization", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"dc", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"cmax", "-", "cmin"}], ")"}], "/", "n"}]}], ";", 
      "\[IndentingNewLine]", 
