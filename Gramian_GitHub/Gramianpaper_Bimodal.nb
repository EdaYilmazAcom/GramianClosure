Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Gramian", " ", 
    RowBox[{"Closure", ":", 
     RowBox[{"The", " ", "Even", " ", "case"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"GramianEven", "[", "momList_", "]"}], ":=", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"len", "=", 
         RowBox[{"Length", "[", "momList", "]"}]}], ",", "s1", ",", "n", ",", 
        "G1", ",", "a1", ",", "a2", ",", "b"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"s1", "=", "1"}], ";", "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Length", "[", "momList", "]"}], "-", "1"}], ")"}], "/", 
         "2"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"G1", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"momList", "[", 
           RowBox[{"[", 
            RowBox[{"i", ";;", 
             RowBox[{"n", "-", "1", "+", "i"}]}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"a1", "=", 
        RowBox[{"momList", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"n", "+", "s1"}], ";;", 
           RowBox[{
            RowBox[{"2", "n"}], "-", "1", "+", "s1"}]}], "]"}], "]"}]}], ";", 
       "                          ", 
