Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"computation", " ", "of", " ", "first", " ", "M"}], "+", 
    RowBox[{
    "1", " ", "moments", " ", "using", " ", "underlying", " ", "distribution",
      " ", "function", " ", "fhid"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"uhid", ",", "uhidnextmoment", ",", "momList"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"uhid", "[", "v2_", "]"}], "=", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"ExpandAll", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", "c", ")"}], "k"], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "0", ",", 
             RowBox[{"Mmax", "+", "1"}]}], "}"}]}], "]"}], 
         RowBox[{"fhid", "[", 
          RowBox[{"c", ",", "v2"}], "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", 
         RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], "]"}]}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"momList", "[", 
      RowBox[{"M_", ",", "v2_"}], "]"}], ":=", 
     RowBox[{"Chop", "[", 
      RowBox[{
       RowBox[{"uhid", "[", "v2", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ";;", 
         RowBox[{"M", "+", "1"}]}], "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"uhidnextmoment", "[", 
      RowBox[{"M_", ",", "v2_"}], "]"}], ":=", 
     RowBox[{"Chop", "[", 
      RowBox[{
       RowBox[{"uhid", "[", "v2", "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"M", "+", "2"}], "]"}], "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9331470500273895`*^9, 3.933147183090827*^9}, {
   3.9332234028549814`*^9, 3.9332234108958673`*^9}, {3.93322368334385*^9, 
