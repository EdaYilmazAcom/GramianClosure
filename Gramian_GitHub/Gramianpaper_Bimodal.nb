     RowBox[{"parameters", ".", " ", "This"}], " ", "function", " ", "will", " ",
      "be", " ", "used", " ", "to", " ", "evaluate", " ", "moments"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fhid", "[", 
      RowBox[{"c_", ",", "v2_"}], "]"}], "=", 
     RowBox[{"fbimodal", "[", 
      RowBox[{
      "\[Rho]1", ",", "v1", ",", "\[Theta]1", ",", "\[Rho]2", ",", "v2", ",", 
       "\[Theta]2", ",", "c"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"fhid", "[", 
    RowBox[{"c", ",", "v2"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "change", " ", "in", " ", "the", " ", "form", " ", "of", " ", "the", " ", 
     "bimodal", " ", "distribution", " ", 
     RowBox[{"w", ".", "r", ".", "t"}], " ", "v2"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fbimodal", "[", 
        RowBox[{
        "\[Rho]1", ",", "v1", ",", "\[Theta]1", ",", "\[Rho]2", ",", "v2", ",",
          "\[Theta]2", ",", "c"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"c", ",", 
         RowBox[{"-", "5"}], ",", "9"}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"v2", ",", "0.5", ",", "4"}], "}"}]}], "]"}]}]}]], "Input",
