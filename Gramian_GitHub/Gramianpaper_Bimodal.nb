Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"fbimodal", ":=", " ", 
    RowBox[{"f_BM", 
     RowBox[{"(", 
      RowBox[{
      "\[Rho]1", ",", "v1", ",", "\[Theta]1", ",", "\[Rho]2", ",", "v2", ",", 
       "\[Theta]2", ",", "c"}], ")"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"fbimodal", "[", 
     RowBox[{
     "\[Rho]1_", ",", "v1_", ",", "\[Theta]1_", ",", "\[Rho]2_", ",", "v2_", ",",
       "\[Theta]2_", ",", "Cc_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Rho]1", "/", 
        RowBox[{"(", 
         RowBox[{"\[Sqrt]", 
          RowBox[{"(", 
           RowBox[{"2", "\[Pi]", " ", "\[Theta]1"}], ")"}]}], ")"}]}], ")"}], 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"Cc", "-", "v1"}], ")"}], "2"]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "\[Theta]1"}], ")"}]}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Rho]2", "/", 
        RowBox[{"(", 
         RowBox[{"\[Sqrt]", 
          RowBox[{"(", 
           RowBox[{"2", "\[Pi]", " ", "\[Theta]2"}], ")"}]}], ")"}]}], ")"}], 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"Cc", "-", "v2"}], ")"}], "2"]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "\[Theta]2"}], ")"}]}], "]"}]}]}]}], ";"}]}]], "Input",
 CellChangeTimes->{3.9331469864985933`*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"c5b0e724-588f-4e39-8434-f093924121e8"],

