         RowBox[{"a5", " ", ".", "c"}], "+", 
         RowBox[{"chi", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"momList", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"2", "n"}], "-", "1", "+", "s1"}], "]"}], "]"}], "-", 
               RowBox[{"a4", ".", "c"}]}], ")"}], "2"], "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"momList", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"2", "n"}], "-", "2", "+", "s1"}], "]"}], "]"}], "-", 
              RowBox[{"a3", ".", "c"}]}], ")"}]}], ")"}]}]}]}], ";", 
       "\[IndentingNewLine]", "NextmomentO"}]}], " ", "]"}]}]}]}]], "Input",
